# =============================================================================
# SMTP for contact form + community subscribe (About / home / wallet).
# Restart `npm run dev` after changes. Set the same vars in Vercel.
# =============================================================================

# --- cPanel (production) ---
EMAIL_HOST=mail.elementaprotocol.com
EMAIL_PORT=465
EMAIL_USER=info@elementaprotocol.com
EMAIL_PASS="your-mailbox-password"
EMAIL_FROM=info@elementaprotocol.com
EMAIL_TO=info@elementaprotocol.com
EMAIL_FROM_NAME=Elementa Protocol

# --- Gmail (local testing while DNS/MX is not ready) ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_USER=your@gmail.com
# EMAIL_PASS="your-gmail-app-password"
# EMAIL_FROM=your@gmail.com
# EMAIL_TO=your@gmail.com
# EMAIL_FROM_NAME=Elementa Protocol
