# Copy to `.env.local` (Next.js loads this in dev/prod). Restart `npm run dev` after changes.
# Never commit real credentials — `.env.local` is gitignored.
#
# SMTP configuration
EMAIL_HOST=mail.elementaprotocol.com
EMAIL_PORT=465
EMAIL_USER=info@elementaprotocol.com
EMAIL_PASS=your-mailbox-password
EMAIL_TO=info@elementaprotocol.com
